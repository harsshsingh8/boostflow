{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/order", "destination": "/api/order" },
    { "source": "/api/v2", "destination": "/api/v2" },
    { "source": "/api/paypal/config", "destination": "/api/paypal/config" },
    { "source": "/api/paypal/create-order", "destination": "/api/paypal/create-order" },
    { "source": "/api/paypal/capture-order", "destination": "/api/paypal/capture-order" },
    { "source": "/((?!api/).*)", "destination": "/" }
  ]
}
