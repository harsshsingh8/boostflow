# SMM Panel API Configuration
# Replace with your actual SMM panel provider details

SMM_API_URL=https://your-smm-panel.com/api/v2
SMM_API_KEY=your_api_key_here
SMM_SERVICE_ID=123

# PayPal Configuration
# Get yours at https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENV=sandbox

# Server Port
PORT=3001
